<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="portaudiosharpBeforeBuild" BeforeTargets="BeforeBuild">
    <Message Text="x86 target detected" Importance="normal" Condition="'$(Platform)'=='x86'"/>
    <Message Text="x64 target detected" Importance="normal" Condition="'$(Platform)'=='x64'"/>

    <ItemGroup>
      <FilesToCopy Include="$(MSBuildThisFileDirectory)..\x86\*.*" Condition="'$(Platform)'=='x86'"/>
    </ItemGroup>

    <ItemGroup>
      <FilesToCopy Include="$(MSBuildThisFileDirectory)..\x64\*.*" Condition="'$(Platform)'=='x64'"/>
    </ItemGroup>
    
    <ItemGroup>
      <ConfigFilesToCopy Include="$(MSBuildThisFileDirectory)..\libs\net40\**\*.dll.config" />
    </ItemGroup>

    <Copy
        SourceFiles="@(FilesToCopy)"
        DestinationFiles="@(FilesToCopy->'$(TargetDir)libs\unmanaged\%(Filename)%(Extension)')"
	/>
        
    <Copy
        SourceFiles="@(ConfigFilesToCopy)"
        DestinationFiles="@(ConfigFilesToCopy->'$(TargetDir)libs\managed\%(RecursiveDir)%(Filename)%(Extension)')"
	/>
  </Target>

  <ItemGroup>
	<Reference Include="PortAudioSharp, Version=0.19.3.29235, Culture=neutral, processorArchitecture=MSIL">
		<SpecificVersion>False</SpecificVersion>
		<HintPath>$(MSBuildThisFileDirectory)..\libs\net40\PortAudioSharp.dll</HintPath>
	</Reference>
  </ItemGroup>

</Project>